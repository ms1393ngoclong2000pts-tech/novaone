Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(app|config|database|scripts|storage)(/|$) - [F,L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ public/index.php [L]
</IfModule>

<FilesMatch "\.(env|json|lock|md|sql|sqlite|bak|backup|log)$">
    Require all denied
</FilesMatch>
